# GigaChat: зарегистрируйте приложение на https://developers.sber.ru/studio
VITE_GIGACHAT_CLIENT_ID=
VITE_GIGACHAT_CLIENT_SECRET=
# Обычно: GIGACHAT_API_PERS или GIGACHAT_API_CORP
VITE_GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Прямые URL (если CORS разрешён браузером)
VITE_GIGACHAT_API_BASE=https://gigachat.devices.sberbank.ru/api/v1
VITE_GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth

# В dev: true — запросы через Vite proxy (избегает CORS). В production настройте backend или reverse proxy.
VITE_GIGACHAT_USE_DEV_PROXY=true
